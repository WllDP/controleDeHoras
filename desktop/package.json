{
  "name": "controle-horas",
  "version": "5.1.3",
  "description": "Controle de Horas",
  "main": "src/main.cjs",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "pack": "node scripts/write-version.cjs && electron-builder --dir",
    "dist": "node scripts/write-version.cjs && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.william.controlehoras",
    "productName": "Controle de Horas",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/php/win",
        "to": "resources/php/win"
      },
      {
        "from": "../vendor",
        "to": "vendor"
      },
      {
        "from": "www",
        "to": "www"
      }
    ],
    "asarUnpack": [
      "resources/php/**"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WllDP",
        "repo": "controleDeHoras",
        "releaseType": "release"
      }
    ]
  }
}
